<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.example.bai4.MainActivity">


    <LinearLayout
        android:layout_width="409dp"
        android:layout_height="729dp"
        android:background="#c9c9c9"
        android:orientation="vertical"
        tools:layout_editor_absoluteX="1dp"
        tools:layout_editor_absoluteY="1dp"
        tools:ignore="MissingConstraints">


        <TextView
            android:id="@+id/textView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="MENU KFC"
            android:textColor="#000000"
            android:textSize="18dp"/>

        <CheckBox
            android:id="@+id/cbCoffee"
            android:textColor="#000000"
            android:buttonTint="#000000"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="COFFE (20 000)" />

        <CheckBox
            android:id="@+id/cbKem"
            android:textColor="#000000"
            android:buttonTint="#000000"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="KEM TƯƠI (10 000)" />
        <CheckBox
            android:id="@+id/cbBim"
            android:textColor="#000000"
            android:buttonTint="#000000"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BIMBIM (5000)" />

        <CheckBox
            android:id="@+id/cbSuaChua"
            android:textColor="#000000"
            android:buttonTint="#000000"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SỮA CHUA (6000)" />
        <CheckBox
            android:id="@+id/cbNepCam"
            android:textColor="#000000"
            android:buttonTint="#000000"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SỮA CHUA NẾP CẨM (12 000)" />

        <com.google.android.material.button.MaterialButton
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="40px"
            android:text="Đặt hàng"
            android:textColor="#000000"
            app:backgroundTint="#b6b6b6"
            android:id="@+id/btnDatHang"
            app:cornerRadius="0dp" />


        <TextView
            android:id="@+id/tvTongTien"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Tổng tiền:"
            android:textSize="18dp"
            android:textColor="#000000"
            />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>