<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#c9c9c9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MENU KFC"
            android:textStyle="bold"
            android:textSize="22sp"
            android:gravity="center"
            android:textColor="#000000"
            android:paddingBottom="16dp"/>

        <!-- COFFEE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <CheckBox
                android:id="@+id/cbCoffee"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="COFFE (20 000)"
                android:textColor="#000000"/>

            <EditText
                android:id="@+id/edtCoffee"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:hint="0"
                android:inputType="number"/>
        </LinearLayout>

        <!-- KEM -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <CheckBox
                android:id="@+id/cbKem"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="KEM TƯƠI (10 000)"
                android:textColor="#000000"/>

            <EditText
                android:id="@+id/edtKem"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:hint="0"
                android:inputType="number"/>
        </LinearLayout>

        <!-- BIMBIM -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <CheckBox
                android:id="@+id/cbBim"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="BIMBIM (5 000)"
                android:textColor="#000000"/>

            <EditText
                android:id="@+id/edtBim"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:hint="0"
                android:inputType="number"/>
        </LinearLayout>

        <!-- SỮA CHUA -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <CheckBox
                android:id="@+id/cbSuaChua"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="SỮA CHUA (6 000)"
                android:textColor="#000000"/>

            <EditText
                android:id="@+id/edtSuaChua"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:hint="0"
                android:inputType="number"/>
        </LinearLayout>

        <!-- NẾP CẨM -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <CheckBox
                android:id="@+id/cbNepCam"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="SỮA CHUA NẾP CẨM (12 000)"
                android:textColor="#000000"/>

            <EditText
                android:id="@+id/edtNepCam"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:hint="0"
                android:inputType="number"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnDatHang"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Đặt hàng"
            android:textSize="16sp"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/tvTongTien"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tổng tiền: 0 VND"
            android:textStyle="bold"
            android:textSize="18sp"
            android:gravity="center"
            android:textColor="#000000"/>

    </LinearLayout>
</ScrollView>